{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /HOME/.zeus-prompter/core/optimizer.py",
            "timeout": 28
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /HOME/.zeus-prompter/core/updater.py",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ]
  }
}
